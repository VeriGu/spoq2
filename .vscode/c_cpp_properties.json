{
    "configurations": [
        {
            "name": "Spoq",
            "includePath": [
                "${workspaceFolder}/**",
                // "${workspaceFolder}/src/AutoV/Spec/Parser/antlr4/runtime/Cpp/runtime/src/",
                "${workspaceFolder}/include",
                // "${workspaceFolder}/include/z3"
                "/usr/lib/llvm-14/include"
            ],
            "defines": [],
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-clang-x64",
